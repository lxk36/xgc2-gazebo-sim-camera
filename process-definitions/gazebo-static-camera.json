{
  "apiVersion": "xgc.execution.process/v1",
  "definitions": [
    {
      "id": "gazebo-static-camera",
      "version": "0.1.0",
      "label": "Gazebo fixed-site RGB camera",
      "description": "Starts an independent Gazebo Classic fixed-site camera with the physical-camera ROS topic contract.",
      "drivers": ["host"],
      "parameters": {
        "properties": {
          "rosMasterUri": {"type": "string", "default": "http://127.0.0.1:11311"},
          "cameraNamespace": {"type": "string", "default": "usb_cam"},
          "modelName": {"type": "string", "default": "gazebo_static_camera"},
          "cameraLinkFrame": {"type": "string", "default": "usb_cam_link"},
          "opticalFrame": {"type": "string", "default": "usb_cam_optical_frame"},
          "gtCameraLinkFrame": {"type": "string", "default": "usb_cam_link_gt"},
          "gtOpticalFrame": {"type": "string", "default": "usb_cam_optical_frame_gt"},
          "width": {"type": "integer", "default": 1920, "minimum": 16, "maximum": 8192},
          "height": {"type": "integer", "default": 1080, "minimum": 16, "maximum": 8192},
          "fps": {"type": "number", "default": 30.0, "minimum": 0.1, "maximum": 240.0},
          "hfov": {"type": "number", "default": 1.3962634, "minimum": 0.1, "maximum": 3.0},
          "x": {"type": "number", "default": -4.0},
          "y": {"type": "number", "default": 0.0},
          "z": {"type": "number", "default": 1.5},
          "roll": {"type": "number", "default": 0.0},
          "pitch": {"type": "number", "default": 0.0},
          "yaw": {"type": "number", "default": 0.0},
          "mode": {"type": "string", "default": "truth", "enum": ["truth", "calibration", "validation"]},
          "publishTruthTf": {"type": "boolean", "default": true},
          "gui": {"type": "boolean", "default": false}
        },
        "additionalProperties": false
      },
      "command": {
        "executable": "/opt/ros/noetic/bin/roslaunch",
        "args": [
          "gazebo_sim_camera", "static_camera.launch",
          "camera_namespace:=${cameraNamespace}", "model_name:=${modelName}",
          "camera_link_frame:=${cameraLinkFrame}", "optical_frame:=${opticalFrame}",
          "gt_camera_link_frame:=${gtCameraLinkFrame}", "gt_optical_frame:=${gtOpticalFrame}",
          "width:=${width}", "height:=${height}", "fps:=${fps}", "hfov:=${hfov}",
          "x:=${x}", "y:=${y}", "z:=${z}", "roll:=${roll}", "pitch:=${pitch}", "yaw:=${yaw}",
          "mode:=${mode}", "publish_truth_tf:=${publishTruthTf}", "gui:=${gui}"
        ],
        "env": {
          "ROS_MASTER_URI": "${rosMasterUri}",
          "PATH": "/opt/ros/noetic/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
          "PYTHONPATH": "/opt/ros/noetic/lib/python3/dist-packages",
          "LD_LIBRARY_PATH": "/opt/ros/noetic/lib",
          "ROS_PACKAGE_PATH": "/opt/ros/noetic/share"
        },
        "directExecutable": true
      },
      "readiness": {
        "kind": "exec",
        "command": {
          "executable": "/opt/ros/noetic/bin/rostopic",
          "args": ["echo", "-n", "1", "/${cameraNamespace}/image_raw/header/stamp"],
          "env": {
            "ROS_MASTER_URI": "${rosMasterUri}",
            "PATH": "/opt/ros/noetic/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
            "PYTHONPATH": "/opt/ros/noetic/lib/python3/dist-packages"
          },
          "directExecutable": true
        }
      },
      "liveness": {"kind": "process"},
      "stop": {},
      "restart": {"mode": "on-failure", "maxRestarts": 3}
    }
  ]
}
