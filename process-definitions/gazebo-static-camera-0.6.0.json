{
  "apiVersion": "xgc.execution.process/v1",
  "definitions": [
    {
      "id": "gazebo-static-camera",
      "version": "0.6.0",
      "label": "Gazebo fixed-site RGB camera",
      "description": "Adds one managed GPU-rendered H264/RTP camera source to the currently running Gazebo Classic scene. Live video is served by the paired XGC media edge; ROS is not on the live image path.",
      "drivers": ["host"],
      "parameters": {
        "properties": {
          "rosMasterUri": {"type": "string", "default": "http://127.0.0.1:11311"},
          "gazeboMasterPort": {"type": "integer", "default": 11345, "minimum": 1, "maximum": 65535},
          "startGazebo": {"type": "boolean", "default": false},
          "cameraStatic": {"type": "boolean", "default": true},
          "modelName": {"type": "string", "default": "gazebo_static_camera"},
          "cameraLinkFrame": {"type": "string", "default": "usb_cam_link"},
          "opticalFrame": {"type": "string", "default": "usb_cam_optical_frame"},
          "gtCameraLinkFrame": {"type": "string", "default": "usb_cam_link_gt"},
          "gtOpticalFrame": {"type": "string", "default": "usb_cam_optical_frame_gt"},
          "width": {"type": "integer", "default": 3840, "minimum": 16, "maximum": 8192},
          "height": {"type": "integer", "default": 2160, "minimum": 16, "maximum": 8192},
          "fps": {"type": "number", "default": 30.0, "minimum": 0.1, "maximum": 240.0},
          "hfov": {"type": "number", "default": 2.44346095, "minimum": 0.1, "maximum": 3.0},
          "mediaSourceId": {"type": "string", "default": "usb_cam"},
          "mediaRtpPort": {"type": "integer", "default": 5004, "minimum": 1, "maximum": 65535},
          "mediaControlSocket": {"type": "string", "default": "/tmp/xgc2/media/usb_cam.sock"},
          "mediaBitrate": {"type": "integer", "default": 24000000, "minimum": 128000, "maximum": 100000000},
          "mediaMaxBitrate": {"type": "integer", "default": 36000000, "minimum": 128000, "maximum": 100000000},
          "mediaPacingBitrate": {"type": "integer", "default": 72000000, "minimum": 128000, "maximum": 200000000},
          "mediaVbvBufferMilliseconds": {"type": "integer", "default": 500, "minimum": 50, "maximum": 2000},
          "snapshotJpegQuality": {"type": "integer", "default": 90, "minimum": 50, "maximum": 100},
          "x": {"type": "number", "default": -4.0},
          "y": {"type": "number", "default": 0.0},
          "z": {"type": "number", "default": 1.5},
          "roll": {"type": "number", "default": 0.0},
          "pitch": {"type": "number", "default": 0.0},
          "yaw": {"type": "number", "default": 0.0},
          "mode": {"type": "string", "default": "truth", "enum": ["truth", "calibration", "validation"]},
          "publishTruthTf": {"type": "boolean", "default": true},
          "gui": {"type": "boolean", "default": false}
        },
        "additionalProperties": false
      },
      "resourceClaims": [
        {
          "bindingKey": "gazebo-model",
          "kind": "custom",
          "mode": "",
          "capacity": 0,
          "namespace": "gazebo-model",
          "identityParts": [
            {"parameter": "gazeboMasterPort"},
            {"parameter": "modelName"}
          ]
        }
      ],
      "command": {
        "executable": "/opt/ros/noetic/bin/roslaunch",
        "args": [
          "gazebo_sim_camera", "static_camera.launch",
          "start_gazebo:=${startGazebo}",
          "static:=${cameraStatic}",
          "model_name:=${modelName}",
          "camera_link_frame:=${cameraLinkFrame}", "optical_frame:=${opticalFrame}",
          "gt_camera_link_frame:=${gtCameraLinkFrame}", "gt_optical_frame:=${gtOpticalFrame}",
          "width:=${width}", "height:=${height}", "fps:=${fps}", "hfov:=${hfov}",
          "media_source_id:=${mediaSourceId}", "media_rtp_port:=${mediaRtpPort}",
          "media_control_socket:=${mediaControlSocket}", "media_bitrate:=${mediaBitrate}",
          "media_max_bitrate:=${mediaMaxBitrate}", "media_pacing_bitrate:=${mediaPacingBitrate}",
          "media_vbv_buffer_milliseconds:=${mediaVbvBufferMilliseconds}",
          "snapshot_jpeg_quality:=${snapshotJpegQuality}",
          "x:=${x}", "y:=${y}", "z:=${z}", "roll:=${roll}", "pitch:=${pitch}", "yaw:=${yaw}",
          "mode:=${mode}", "publish_truth_tf:=${publishTruthTf}", "gui:=${gui}"
        ],
        "env": {
          "GAZEBO_MASTER_URI": "http://127.0.0.1:${gazeboMasterPort}",
          "ROS_MASTER_URI": "${rosMasterUri}",
          "PATH": "/opt/ros/noetic/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
          "PYTHONPATH": "/opt/ros/noetic/lib/python3/dist-packages",
          "LD_LIBRARY_PATH": "/opt/ros/noetic/lib",
          "ROS_PACKAGE_PATH": "/opt/ros/noetic/share"
        },
        "directExecutable": true
      },
      "beforeStart": {
        "command": {
          "executable": "/opt/ros/noetic/bin/rosservice",
          "args": ["call", "/gazebo/delete_model", "model_name: '${modelName}'"],
          "directExecutable": true,
          "env": {
            "GAZEBO_MASTER_URI": "http://127.0.0.1:${gazeboMasterPort}",
            "ROS_MASTER_URI": "${rosMasterUri}",
            "PATH": "/opt/ros/noetic/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
            "PYTHONPATH": "/opt/ros/noetic/lib/python3/dist-packages"
          }
        },
        "timeout": 5000000000
      },
      "beforeStop": {
        "command": {
          "executable": "/opt/ros/noetic/bin/rosservice",
          "args": ["call", "/gazebo/delete_model", "model_name: '${modelName}'"],
          "directExecutable": true,
          "env": {
            "GAZEBO_MASTER_URI": "http://127.0.0.1:${gazeboMasterPort}",
            "ROS_MASTER_URI": "${rosMasterUri}",
            "PATH": "/opt/ros/noetic/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin",
            "PYTHONPATH": "/opt/ros/noetic/lib/python3/dist-packages"
          }
        },
        "timeout": 5000000000
      },
      "readiness": {
        "kind": "exec",
        "command": {
          "executable": "/usr/bin/test",
          "args": ["-S", "${mediaControlSocket}"],
          "directExecutable": true
        },
        "interval": 2000000000,
        "timeout": 5000000000,
        "successThreshold": 1,
        "failureThreshold": 3
      },
      "liveness": {"kind": "process"},
      "stop": {},
      "restart": {"mode": "on-failure", "maxRestarts": 3}
    }
  ]
}
