<?xml version="1.0"?>
<sdf version="1.6">
  <world name="calibration">
    <include><uri>model://sun</uri></include>
    <include><uri>model://ground_plane</uri></include>
    <scene><ambient>0.65 0.65 0.65 1</ambient><background>0.15 0.18 0.22 1</background><shadows>true</shadows></scene>
    <physics name="default_physics" default="0" type="ode"><max_step_size>0.001</max_step_size><real_time_update_rate>1000</real_time_update_rate></physics>
  </world>
</sdf>
