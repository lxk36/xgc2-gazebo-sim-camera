<?xml version="1.0"?>
<launch>
  <arg name="gui" default="true"/>
  <arg name="paused" default="false"/>
  <arg name="keyboard_teleop" default="true"/>
  <arg name="keyboard_linear_step" default="0.15"/>
  <arg name="keyboard_angular_step" default="0.05"/>
  <!-- Spawn the camera movable (gravity-off, not <static>) so the keyboard
       teleop and drive_intrinsic_calibration.py can actually reposition it. -->
  <arg name="camera_static" default="false"/>
  <arg name="model_name" default="gazebo_static_camera"/>
  <arg name="camera_link_frame" default="usb_cam_link"/>
  <arg name="optical_frame" default="usb_cam_optical_frame"/>
  <arg name="camera_profile" default="world_ultrawide_4k30_140"/>
  <arg name="camera_profiles_file"
       default="$(find gazebo_sim_camera)/config/world_camera_profiles.yaml"/>
  <arg name="width" default="profile"/>
  <arg name="height" default="profile"/>
  <arg name="fps" default="profile"/>
  <arg name="hfov" default="profile"/>
  <arg name="media_source_id" default="usb_cam"/>
  <arg name="media_rtp_port" default="5004"/>
  <arg name="media_control_socket" default="/tmp/xgc2/media/usb_cam.sock"/>
  <arg name="media_bitrate" default="profile"/>
  <arg name="media_max_bitrate" default="profile"/>
  <arg name="media_pacing_bitrate" default="profile"/>
  <arg name="media_vbv_buffer_milliseconds" default="profile"/>
  <arg name="camera_x" default="-4.0"/><arg name="camera_y" default="0.0"/><arg name="camera_z" default="1.5"/>
  <arg name="camera_roll" default="0.0"/><arg name="camera_pitch" default="0.0"/><arg name="camera_yaw" default="0.0"/>
  <arg name="board_x" default="2.0"/><arg name="board_y" default="0.0"/><arg name="board_z" default="1.5"/>
  <arg name="board_roll" default="0.0"/><arg name="board_pitch" default="0.0"/><arg name="board_yaw" default="0.0"/>

  <include file="$(dirname)/static_camera.launch">
    <arg name="world" value="$(find gazebo_sim_worlds)/worlds/camera_calibration_intrinsic/camera_calibration_intrinsic.world"/>
    <arg name="paused" value="$(arg paused)"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="keyboard_gui" value="$(arg keyboard_teleop)"/>
    <arg name="model_name" value="$(arg model_name)"/>
    <arg name="static" value="$(arg camera_static)"/>
    <arg name="camera_link_frame" value="$(arg camera_link_frame)"/>
    <arg name="optical_frame" value="$(arg optical_frame)"/>
    <arg name="camera_profile" value="$(arg camera_profile)"/>
    <arg name="camera_profiles_file" value="$(arg camera_profiles_file)"/>
    <arg name="width" value="$(arg width)"/><arg name="height" value="$(arg height)"/>
    <arg name="fps" value="$(arg fps)"/><arg name="hfov" value="$(arg hfov)"/>
    <arg name="media_source_id" value="$(arg media_source_id)"/>
    <arg name="media_rtp_port" value="$(arg media_rtp_port)"/>
    <arg name="media_control_socket" value="$(arg media_control_socket)"/>
    <arg name="media_bitrate" value="$(arg media_bitrate)"/>
    <arg name="media_max_bitrate" value="$(arg media_max_bitrate)"/>
    <arg name="media_pacing_bitrate" value="$(arg media_pacing_bitrate)"/>
    <arg name="media_vbv_buffer_milliseconds" value="$(arg media_vbv_buffer_milliseconds)"/>
    <arg name="x" value="$(arg camera_x)"/><arg name="y" value="$(arg camera_y)"/><arg name="z" value="$(arg camera_z)"/>
    <arg name="roll" value="$(arg camera_roll)"/><arg name="pitch" value="$(arg camera_pitch)"/><arg name="yaw" value="$(arg camera_yaw)"/>
    <arg name="mode" value="truth"/><arg name="publish_truth_tf" value="true"/>
  </include>

  <!-- The checkerboard (model://checkerboard_8x6) is composed into the shared
       camera_calibration_intrinsic world; no separate spawn is needed. -->

  <node if="$(arg keyboard_teleop)" pkg="gazebo_sim_camera"
        type="keyboard_camera_teleop.py" name="gazebo_camera_keyboard_teleop"
        output="screen" required="false"
        args="--model-name $(arg model_name) --linear-step $(arg keyboard_linear_step) --angular-step $(arg keyboard_angular_step)"/>
</launch>
