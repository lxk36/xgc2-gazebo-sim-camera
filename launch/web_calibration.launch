<?xml version="1.0"?>
<!--
  Browser calibration UI (reuses the ROS camera_calibration CV engine) plus
  topic-based camera teleop.  Run this against an already-running intrinsic
  world, and start that world with keyboard_teleop:=false so this node is the
  only authority on /gazebo/set_model_state:

    roslaunch gazebo_sim_camera intrinsic_calibration_world.launch \
      gui:=true keyboard_teleop:=false
    roslaunch gazebo_sim_camera web_calibration.launch
    # then open http://localhost:8080
-->
<launch>
  <arg name="camera_namespace" default="usb_cam"/>
  <arg name="image_topic" default="/usb_cam/image_raw"/>
  <arg name="model_name" default="gazebo_static_camera"/>
  <arg name="port" default="8080"/>
  <arg name="board_size" default="7x5"/>
  <arg name="square" default="0.20"/>
  <arg name="linear_step" default="0.15"/>
  <arg name="angular_step" default="0.05"/>
  <!-- Extra CLI flags passed through verbatim, e.g. the no-camera-control or
       no-service-check switches (each written with two leading dashes). -->
  <arg name="extra_args" default=""/>

  <node pkg="gazebo_sim_camera" type="web_calibration.py" name="web_calibration" output="screen" required="false"
        args="--size $(arg board_size) --square $(arg square) --camera $(arg camera_namespace)
              --port $(arg port) --model-name $(arg model_name)
              --linear-step $(arg linear_step) --angular-step $(arg angular_step) $(arg extra_args)">
    <remap from="image" to="$(arg image_topic)"/>
    <remap from="camera" to="$(arg camera_namespace)"/>
  </node>
</launch>
