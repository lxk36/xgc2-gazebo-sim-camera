<?xml version="1.0"?>
<launch>
  <include file="$(find gazebo_sim_camera)/launch/static_camera.launch">
    <arg name="gui" value="false"/>
    <arg name="model_name" value="gazebo_static_camera_contract"/>
    <arg name="camera_link_frame" value="contract_camera_link"/>
    <arg name="optical_frame" value="contract_camera_optical_frame"/>
    <arg name="camera_profile" value="calibration_standard_720p20"/>
    <arg name="media_source_id" value="contract_camera"/>
    <arg name="media_rtp_port" value="15004"/>
    <arg name="media_control_socket" value="/tmp/xgc2/media/contract_camera.sock"/>
    <arg name="mode" value="truth"/>
    <arg name="publish_truth_tf" value="true"/>
  </include>
  <test test-name="static_camera_contract" pkg="gazebo_sim_camera"
        type="camera_contract_test.py" time-limit="90">
    <param name="control_socket" value="/tmp/xgc2/media/contract_camera.sock"/>
    <param name="frame_id" value="contract_camera_optical_frame"/>
    <param name="parent_frame" value="map"/>
    <param name="width" value="1280"/>
    <param name="height" value="720"/>
    <param name="hfov" value="1.3962634015954636"/>
  </test>
</launch>
