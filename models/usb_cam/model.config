<?xml version="1.0"?>
<model>
  <name>usb_cam</name>
  <version>1.0</version>
  <sdf version="1.6">model.sdf</sdf>
  <author><name>XGC2</name><email>dev@xiaokang.ink</email></author>
  <description>
    Topic-controllable fixed-site RGB scene camera (4K). Not static and gravity
    off, so /gazebo/set_model_state can relocate it. Publishes /usb_cam/image_raw
    and /usb_cam/camera_info via libgazebo_ros_camera; image frame is
    usb_cam_optical_frame.
  </description>
</model>
